<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="12dp"
    android:paddingHorizontal="4dp">

    <TextView
        android:id="@+id/tvStepNumber"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_step_number"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStepInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/synchef_text_dark"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4" />

        <!-- Timer tag -->
        <TextView
            android:id="@+id/tvStepTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/synchef_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Temperature tag -->
        <TextView
            android:id="@+id/tvStepTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_tag"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/synchef_orange"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Tip -->
        <TextView
            android:id="@+id/tvStepTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textColor="@color/synchef_text_light"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
