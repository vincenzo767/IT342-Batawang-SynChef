<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="#0D1118"
    android:orientation="vertical"
    android:padding="8dp">

    <ImageView
        android:id="@+id/imgSynCook"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tvSynCookTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSynCookMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#9CA3AF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvSynCookComments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#D1D5DB"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSynCookView"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_button_secondary"
            android:text="View"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSynCookEdit"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Edit"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSynCookDelete"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Delete"
            android:textAllCaps="false"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
