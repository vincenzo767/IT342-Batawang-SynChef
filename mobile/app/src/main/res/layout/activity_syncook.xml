<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1D2636"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Let's SynCook!"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="start"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSynCookCreate"
            android:layout_width="90dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_explore"
            android:text="Create"
            android:textAllCaps="false"
            android:textColor="@color/synchef_primary_dark"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSynCookManage"
            android:layout_width="90dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_explore"
            android:text="Manage"
            android:textAllCaps="false"
            android:textColor="@color/synchef_primary_dark"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Explore's Local Recipe's"
        android:textColor="#E5E7EB"
        android:textSize="13sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etSynCookSearch"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input"
        android:hint="Search"
        android:paddingHorizontal="10dp"
        android:textColor="@color/synchef_text_dark"
        android:textColorHint="@color/synchef_text_hint" />

    <TextView
        android:id="@+id/tvSynCookStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Loading SynCook recipes..."
        android:textColor="#D1D5DB"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSynCookRecipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <include layout="@layout/view_bottom_nav" />

</LinearLayout>
