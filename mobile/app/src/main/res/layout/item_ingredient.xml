<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp"
    android:paddingHorizontal="4dp">

    <View
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/synchef_primary"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/tvIngredientAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="60dp"
        android:textColor="@color/synchef_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvIngredientName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:textColor="@color/synchef_text_dark"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvOptional"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_tag"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="Optional"
        android:textColor="@color/synchef_text_light"
        android:textSize="10sp"
        android:visibility="gone" />

</LinearLayout>
